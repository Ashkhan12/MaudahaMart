const getExpectedPlatform = (trainNumber: string, stationName: string): number => {
  const cleanName = stationName.toLowerCase();
  let maxPlatforms = 3;
  if (cleanName.includes('kanpur') || cleanName.includes('cnb')) {
    maxPlatforms = 10;
  } else if (cleanName.includes('lucknow') || cleanName.includes('ljn') || cleanName.includes('gwalior') || cleanName.includes('gwl') || cleanName.includes('prayagraj') || cleanName.includes('jabalpur') || cleanName.includes('howrah') || cleanName.includes('hwh') || cleanName.includes('ltt') || cleanName.includes('mumbai')) {
    maxPlatforms = 8;
  } else if (cleanName.includes('banda') || cleanName.includes('satna') || cleanName.includes('manikpur') || cleanName.includes('raipur') || cleanName.includes('durg')) {
    maxPlatforms = 5;
  } else if (cleanName.includes('ragaul') || cleanName.includes('maudaha') || cleanName.includes('sumerpur') || cleanName.includes('atarra') || cleanName.includes('karwi') || cleanName.includes('ghatampur')) {
    maxPlatforms = 3;
  }
  
  const charSum = stationName.split('').reduce((sum, char) => sum + char.charCodeAt(0), 0);
  const trainNum = parseInt(trainNumber) || 101;
  return ((charSum + trainNum) % maxPlatforms) + 1;
};

export default function TrainStatusCorner({
  activeUserId,
  users,
  onUpdateUsers,
  language,
  onAddActivity
}: TrainStatusCornerProps) {
  const [trainNo, setTrainNo] = useState('');
  const [pnrNo, setPnrNo] = useState('');
  const [searchResult, setSearchResult] = useState<any | null>(null);
  const [pnrResult, setPnrResult] = useState<any | null>(null);
  const [activeSubTab, setActiveSubTab] = useState<'status' | 'pnr' | 'popular' | 'book'>('popular');
  const [errorMsg, setErrorMsg] = useState('');

  // Recent searched routes interface & state
  interface RecentRoute {
    from: string;
    to: string;
    timestamp: number;
  }
  const [recentRoutes, setRecentRoutes] = useState<RecentRoute[]>([]);

  useEffect(() => {
    const key = `maudahajunction_recent_routes_${activeUserId}`;
    try {
      const stored = localStorage.getItem(key);
      if (stored) {
        setRecentRoutes(JSON.parse(stored));
      } else {
        setRecentRoutes([]);
      }
    } catch (e) {
      setRecentRoutes([]);
    }
  }, [activeUserId]);

  const saveRecentRoute = (from: string, to: string) => {
    if (!from || !to) return;
    const key = `maudahajunction_recent_routes_${activeUserId}`;
    setRecentRoutes((prev) => {
      const filtered = prev.filter(
        (r) => !(r.from.toLowerCase() === from.toLowerCase() && r.to.toLowerCase() === to.toLowerCase())
      );
      const newRoute: RecentRoute = { from, to, timestamp: Date.now() };
      const updated = [newRoute, ...filtered].slice(0, 5); // Limit to last 5 searches
      try {
        localStorage.setItem(key, JSON.stringify(updated));
      } catch (e) {
        console.error(e);
      }
      return updated;
    });
  };

  const handleClearRecentRoutes = () => {
    const key = `maudahajunction_recent_routes_${activeUserId}`;
    try {
      localStorage.removeItem(key);
    } catch (e) {
      console.error(e);
    }
    setRecentRoutes([]);
  };

  const handleSelectRecentRoute = (route: RecentRoute) => {
    setFromStation(route.from);
    setToStation(route.to);
    setSearchedBookings(true);
    setSelectedTrain(null);
    setShowPaymentGateway(false);
    setBookedTicket(null);
    setSelectedSeat(null);
  };

  // Train Booking states
  const [fromStation, setFromStation] = useState('Ragaul (RGU)');
  const [toStation, setToStation] = useState('Kanpur Central');
  const [bookingDate, setBookingDate] = useState('2026-07-16');
  const [passenger, setPassenger] = useState('');
  const [selectedClass, setSelectedClass] = useState<'SL' | '3A' | '2A' | '1A'>('3A');
  const [searchedBookings, setSearchedBookings] = useState(false);
  const [selectedTrain, setSelectedTrain] = useState<any | null>(null);
  const [selectedSeat, setSelectedSeat] = useState<string | null>(null);
  const [showPaymentGateway, setShowPaymentGateway] = useState(false);
  const [customerUpiId, setCustomerUpiId] = useState('');
  const [paymentVerifying, setPaymentVerifying] = useState(false);
  const [bookedTicket, setBookedTicket] = useState<any | null>(null);

  const COACH_CLASSES = [
    { code: 'SL', name: 'Sleeper Class (SL)', nameHi: 'स्लीपर क्लास (SL)', basePrice: 150, seatPrefix: 'S3 -' },
    { code: '3A', name: 'AC 3 Tier (3A)', nameHi: 'एसी 3 टियर (3A)', basePrice: 480, seatPrefix: 'B1 -' },
    { code: '2A', name: 'AC 2 Tier (2A)', nameHi: 'एसी 2 टियर (2A)', basePrice: 850, seatPrefix: 'A1 -' },
    { code: '1A', name: 'AC First Class (1A)', nameHi: 'एसी प्रथम श्रेणी (1A)', basePrice: 1600, seatPrefix: 'H1 -' },
  ];

  const cleanStationName = (name: string) => {
    return name.toLowerCase()
      .replace(/\(.*\)/g, '') // remove parentheses and anything inside, like (MXM) or (RGU)
      .replace(/\b(jn|junction|central|station|stn)\b/gi, '') // remove common station suffix words
      .replace(/[^a-z0-9\s]/gi, '') // remove non-alphanumeric chars
      .replace(/\s+/g, ' ') // replace multiple spaces with single space
      .trim();
  };

  const findStationIndex = (stations: any[], queryName: string) => {
    const cleanQuery = cleanStationName(queryName);
    if (!cleanQuery) return -1;
    return stations.findIndex(st => {
      const cleanStName = cleanStationName(st.name);
      return cleanStName.includes(cleanQuery) || cleanQuery.includes(cleanStName);
    });
  };

  const calculateDuration = (depTime: string, arrTime: string): string => {
    const parseTime = (tStr: string) => {
      const match = tStr.match(/(\d+):(\d+)\s*(AM|PM)/i);
      if (!match) return 0;
      let hours = parseInt(match[1], 10);
      const minutes = parseInt(match[2], 10);
      const modifier = match[3].toUpperCase();
      if (modifier === 'PM' && hours < 12) hours += 12;
      if (modifier === 'AM' && hours === 12) hours = 0;
      return hours * 60 + minutes;
    };
    try {
      const depMin = parseTime(depTime);
      let arrMin = parseTime(arrTime);
      if (arrMin < depMin) arrMin += 24 * 60; // next day
      const diff = arrMin - depMin;
      const h = Math.floor(diff / 60);
      const m = diff % 60;
      return `${h}h ${m}m`;
    } catch (e) {
      return '2h 30m';
    }
  };

  const getMockTrains = () => {
    const fStr = fromStation.trim() || 'Ragaul (RGU)';
    const tStr = toStation.trim() || 'Kanpur Central';

    // Try to find dynamic matches in our POPULAR_TRAINS dataset first
    const dynamicMatches: any[] = [];
    POPULAR_TRAINS.forEach(train => {
      const fromIdx = findStationIndex(train.stations, fStr);
      const toIdx = findStationIndex(train.stations, tStr);
      if (fromIdx !== -1 && toIdx !== -1 && fromIdx < toIdx) {
        const depTime = train.stations[fromIdx].time;
        const arrTime = train.stations[toIdx].time;
        const duration = calculateDuration(depTime, arrTime);
        
        const runsOn = language === 'en' ? (train.runsOn || 'Daily') : (train.runsOnHi || train.runsOn || 'रोजाना');

        // Clean train names for bilingual rendering
        const cleanName = train.name.split('(')[0].trim();
        const cleanNameHi = train.nameHi.split('(')[0].trim();

        dynamicMatches.push({
          number: train.number,
          name: cleanName,
          nameHi: cleanNameHi,
          basePrice: 180 + (toIdx - fromIdx) * 35, // Distance-based pricing
          departureTime: depTime,
          arrivalTime: arrTime,
          duration: duration,
          runsOn: runsOn
        });
      }
    });

    if (dynamicMatches.length > 0) {
      return dynamicMatches;
    }

    // Default template fallback for generic searches (e.g. Ragaul/Kanpur directly or custom stations)
    const isRagaul = fStr.toLowerCase().includes('ragaul') || fStr.toLowerCase().includes('maudaha') || fStr.toUpperCase().includes('RGU') || fStr.toUpperCase().includes('MXM');
    const isKanpur = tStr.toLowerCase().includes('kanpur') || tStr.toUpperCase().includes('CNB');

    if (isRagaul || isKanpur) {
      // Clean fallback for Ragaul-Kanpur route if no exact station index matched
      return [
        {
          number: '11108',
          name: 'Bundelkhand Express',
          nameHi: 'बुंदेलखंड एक्सप्रेस',
          basePrice: 280,
          departureTime: '12:35 PM',
          arrivalTime: '03:10 PM',
          duration: '2h 35m',
          runsOn: 'Daily'
        },
        {
          number: '15206',
          name: 'Chitrakoot Express',
          nameHi: 'चित्रकूट एक्सप्रेस',
          basePrice: 320,
          departureTime: '04:45 AM',
          arrivalTime: '07:20 AM',
          duration: '2h 35m',
          runsOn: 'Daily'
        },
        {
          number: '18203',
          name: 'Betwa Express',
          nameHi: 'बेत्वा एक्सप्रेस',
          basePrice: 310,
          departureTime: '11:22 AM',
          arrivalTime: '01:20 PM',
          duration: '1h 58m',
          runsOn: 'Mon, Wed'
        },
        {
          number: '12175',
          name: 'Chambal Express',
          nameHi: 'चंबल एक्सप्रेस',
          basePrice: 330,
          departureTime: '08:12 AM',
          arrivalTime: '10:20 AM',
          duration: '2h 08m',
          runsOn: 'Mon, Wed, Fri'
        }
      ];
    }

    // Generic other station search fallback
    return [
      {
        number: '12451',
        name: `${fStr} ↔ ${tStr} Shram Shakti SF`,
        nameHi: `${fStr} ↔ ${tStr} श्रम शक्ति सुपरफास्ट`,
        basePrice: 420,
        departureTime: '06:15 AM',
        arrivalTime: '11:45 AM',
        duration: '5h 30m',
        runsOn: 'Daily'
      },
      {
        number: '12175',
        name: `${fStr} ↔ ${tStr} Chambal Superfast`,
        nameHi: `${fStr} ↔ ${tStr} चंबल सुपरफास्ट`,
        basePrice: 380,
        departureTime: '11:30 AM',
        arrivalTime: '05:40 PM',
        duration: '6h 10m',
        runsOn: 'Mon, Wed, Fri'
      },
      {
        number: '15206',
        name: `${fStr} ↔ ${tStr} Chitrakoot Express`,
        nameHi: `${fStr} ↔ ${tStr} चित्रकूट एक्सप्रेस`,
        basePrice: 310,
        departureTime: '03:45 PM',
        arrivalTime: '10:15 PM',
        duration: '6h 30m',
        runsOn: 'Daily'
      },
      {
        number: '11107',
        name: `${fStr} ↔ ${tStr} Bundelkhand Express`,
        nameHi: `${fStr} ↔ ${tStr} बुंदेलखंड एक्सप्रेस`,
        basePrice: 240,
        departureTime: '09:50 PM',
        arrivalTime: '05:20 AM',
        duration: '7h 30m',
        runsOn: 'Daily'
      }
    ];
  };

  const handleSearchBookings = (e: React.FormEvent) => {
    e.preventDefault();
    setSearchedBookings(true);
    setSelectedTrain(null);
    setShowPaymentGateway(false);
    setBookedTicket(null);
    setSelectedSeat(null);

    const fromVal = fromStation.trim();
    const toVal = toStation.trim();
    if (fromVal && toVal) {
      saveRecentRoute(fromVal, toVal);
    }
  };

  const handleBookTrainTicket = (priceValue: number, adminProfitValue: number) => {
    if (!selectedTrain) return;
    const finalPassenger = passenger.trim() || currentUser?.name || 'Guest Passenger';
    const classObj = COACH_CLASSES.find(c => c.code === selectedClass);
    const finalSeat = selectedSeat || `${classObj?.seatPrefix || 'B1-'} Berth ${Math.floor(Math.random() * 64) + 1} (Lower)`;

    const newBooking: TrainBooking = {
      id: `tr-bk-${Date.now()}`,
      trainNumber: selectedTrain.number,
      trainName: selectedTrain.name,
      trainNameHi: selectedTrain.nameHi,
      from: fromStation,
      to: toStation,
      departureTime: selectedTrain.departureTime,
      departureDate: bookingDate,
      arrivalTime: selectedTrain.arrivalTime,
      seat: finalSeat,
      passengerName: finalPassenger,
      className: classObj ? (language === 'hi' ? classObj.nameHi : classObj.name) : 'AC 3 Tier (3A)',
      qrCode: `TRAIN-${selectedTrain.number}-${finalSeat.replace(/\s+/g, '')}-${Date.now()}`,
      price: priceValue,
      adminProfit: adminProfitValue,
      adminUpiId: 'dingdang7081@okhdfcbank',
      paymentStatus: 'completed'
    };

    onUpdateUsers(prevUsers =>
      prevUsers.map(u => {
        if (u.id === activeUserId) {
          const bks = u.trainBookings || [];
          return {
            ...u,
            trainBookings: [newBooking, ...bks]
          };
        }
        return u;
      })
    );

    onAddActivity(
      activeUserId,
      `Booked train ticket ${selectedTrain.number} from ${fromStation} to ${toStation} (₹${priceValue} paid with 2% Admin commission ₹${adminProfitValue} routed to dingdang7081@okhdfcbank)`,
      `ट्रेन टिकट ${selectedTrain.number} ${fromStation} से ${toStation} बुक किया (₹${priceValue} का भुगतान 2% एडमिन लाभांश ₹${adminProfitValue} के साथ यूपीआई dingdang7081@okhdfcbank पर भेजा गया)`
    );

    setBookedTicket(newBooking);
    setShowPaymentGateway(false);
    setSearchedBookings(false);
  };

  const currentUser = users.find(u => u.id === activeUserId);
  const savedQueries = currentUser?.trainQueries || [];

  const handleSearchStatus = (numberOrName: string) => {
    setErrorMsg('');
    const queryTerm = numberOrName.trim();
    if (!queryTerm) return;

    const matched = POPULAR_TRAINS.find(
      t => t.number === queryTerm || t.name.toLowerCase().includes(queryTerm.toLowerCase())
    );

    if (matched) {
      setSearchResult(matched);
      onAddActivity(
        activeUserId,
        `Queried live status for train ${matched.number} (${matched.name})`,
        `ट्रेन ${matched.number} (${matched.nameHi}) की लाइव स्थिति जांची`
      );

      // Save to user history in Firestore/State
      const newQuery: TrainQuery = {
        id: `train-q-${Date.now()}`,
        trainNumber: matched.number,
        trainName: matched.name,
        date: new Date().toLocaleDateString(),
        statusText: matched.status,
        statusTextHi: matched.statusHi
      };

      onUpdateUsers(prevUsers =>
        prevUsers.map(u => {
          if (u.id === activeUserId) {
            const queries = u.trainQueries || [];
            // Avoid duplicates
            if (queries.some(q => q.trainNumber === matched.number)) return u;
            return {
              ...u,
              trainQueries: [newQuery, ...queries]
            };
          }
          return u;
        })
      );
    } else {
      // Simulate highly realistic train generation based on the entered number/name
      const cleanTerm = queryTerm.toUpperCase();
      const isNumeric = /^\d+$/.test(cleanTerm);
      const trainNum = isNumeric ? cleanTerm : `${Math.floor(Math.random() * 90000) + 10000}`;
      const trainName = isNumeric ? `Ragaul - Kanpur Central Special` : `${queryTerm} Express`;
      const trainNameHi = isNumeric ? `रागौल - कानपुर सेंट्रल स्पेशल` : `${queryTerm} एक्सप्रेस`;

      const randomDelay = Math.random() > 0.7 ? '20 mins' : 'No delay';
      const randomStatus = randomDelay === 'No delay' ? 'Running on Time' : 'Delayed by 20 mins';
      const randomStatusHi = randomDelay === 'No delay' ? 'समय पर चल रही है' : '20 मिनट की देरी से';
      
      const generated = {
        number: trainNum,
        name: trainName,
        nameHi: trainNameHi,
        route: 'Banda Jn ↔ Kanpur Central via Ragaul',
        routeHi: 'बांदा जंक्शन ↔ कानपुर सेंट्रल वाया रागौल',
        time: '03:45 PM at Ragaul (RGU)',
        status: randomStatus,
        statusHi: randomStatusHi,
        delay: randomDelay,
        delayHi: randomDelay === 'No delay' ? 'कोई देरी नहीं' : '20 मिनट',
        stations: [
          { name: 'Banda Jn', nameHi: 'बांदा जंक्शन', time: '01:15 PM', status: 'departed' },
          { name: 'Matihili', nameHi: 'मतिहिली', time: '01:50 PM', status: 'departed' },
          { name: 'Ragaul (RGU)', nameHi: 'रागौल (आरजीयू)', time: '03:45 PM', status: 'active' },
          { name: 'Bharuwa Sumerpur', nameHi: 'भरुआ सुमेरपुर', time: '04:15 PM', status: 'upcoming' },
          { name: 'Kathara', nameHi: 'कठारा', time: '04:50 PM', status: 'upcoming' },
          { name: 'Ghatampur', nameHi: 'घाटमपुर', time: '05:30 PM', status: 'upcoming' },
          { name: 'Kanpur Central (CNB)', nameHi: 'कानपुर सेंट्रल', time: '06:50 PM', status: 'upcoming' }
        ]
      };

      setSearchResult(generated);

      // Save to user history as well!
      const newQuery: TrainQuery = {
        id: `train-q-${Date.now()}`,
        trainNumber: trainNum,
        trainName: trainName,
        date: new Date().toLocaleDateString(),
        statusText: randomStatus,
        statusTextHi: randomStatusHi
      };

      onUpdateUsers(prevUsers =>
        prevUsers.map(u => {
          if (u.id === activeUserId) {
            const queries = u.trainQueries || [];
            if (queries.some(q => q.trainNumber === trainNum)) return u;
            return {
              ...u,
              trainQueries: [newQuery, ...queries]
            };
          }
          return u;
        })
      );

      onAddActivity(
        activeUserId,
        `Queried status for train ${trainNum} (${trainName})`,
        `ट्रेन ${trainNum} (${trainNameHi}) की स्थिति खोजी`
      );
    }
  };

  const handlePnrCheck = () => {
    setErrorMsg('');
    if (!pnrNo.trim() || pnrNo.trim().length !== 10) {
      setErrorMsg(language === 'en' ? 'Please enter a valid 10-digit PNR' : 'कृपया मान्य 10 अंकों का पीएनआर दर्ज करें');
      return;
    }

    // Dynamic mock reservation status
    const mockPnr = {
      pnr: pnrNo,
      train: '11110 - Bundelkhand Express',
      trainHi: '11110 - बुंदेलखंड एक्सप्रेस',
      date: 'Tomorrow',
      dateHi: 'कल',
      from: 'Ragaul (RGU)',
      to: 'Varanasi Jn',
      toHi: 'वाराणसी जंक्शन',
      passengers: [
        { name: 'Passenger 1', seat: 'S3, Berth 24 (Middle)', status: 'CNF (Confirmed)' },
        { name: 'Passenger 2', seat: 'S3, Berth 25 (Upper)', status: 'CNF (Confirmed)' }
      ]
    };

    setPnrResult(mockPnr);
    onAddActivity(activeUserId, `Checked PNR status for ${pnrNo}`, `पीएनआर स्थिति ${pnrNo} की जांच की`);
  };

  const handleDeleteQuery = (queryId: string) => {
    onUpdateUsers(prevUsers =>
      prevUsers.map(u => {
        if (u.id === activeUserId) {
          return {
            ...u,
            trainQueries: (u.trainQueries || []).filter(q => q.id !== queryId)
          };
        }
        return u;
      })
    );
  };

  return (
    <div className="max-w-4xl mx-auto px-4 py-6" id="train-status-corner">
      {/* Header Banner */}
      <div className="bg-gradient-to-r from-indigo-900 via-indigo-850 to-indigo-950 text-white rounded-3xl p-6 md:p-8 shadow-xl mb-6 relative overflow-hidden border border-indigo-950/30">
        <div className="absolute right-0 top-0 translate-x-12 -translate-y-12 bg-white/5 h-44 w-44 rounded-full blur-3xl"></div>
        <div className="absolute left-0 bottom-0 -translate-x-12 translate-y-12 bg-indigo-500/10 h-36 w-36 rounded-full blur-2xl"></div>
        
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 relative z-10">
          <div className="flex items-center gap-4">
            <div className="p-3 bg-white/10 backdrop-blur-md rounded-2xl border border-white/10">
              <Train className="h-8 w-8 text-indigo-300 animate-pulse" />
            </div>
            <div>
              <div className="flex items-center gap-2">
                <h2 className="text-xl md:text-2xl font-black tracking-tight">
                  {language === 'en' ? 'Ragaul (RGU) Live Terminal' : 'रागौल (आरजीयू) लाइव टर्मिनल'}
                </h2>
                <span className="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-black bg-emerald-500/20 text-emerald-400 border border-emerald-500/20 animate-pulse">
                  ● LIVE
                </span>
              </div>
              <p className="text-xs text-indigo-200/90 font-medium mt-1">
                {language === 'en' ? 'RGU station terminal, live status tracking, PNR, & reservations' : 'आरजीयू स्टेशन टर्मिनल, लाइव स्थिति ट्रैकिंग, पीएनआर, और आरक्षण'}
              </p>
            </div>
          </div>
          
          <div className="flex items-center gap-3 self-start md:self-auto bg-white/5 backdrop-blur-sm px-4 py-2.5 rounded-2xl border border-white/5">
            <div className="text-right">
              <span className="text-[9px] font-bold text-indigo-200 block uppercase tracking-wider">
                {language === 'en' ? 'Station Code' : 'स्टेशन कोड'}
              </span>
              <span className="text-sm font-black text-white font-mono">
                RGU / आरजीयू
              </span>
            </div>
          </div>
        </div>
      </div>

      {/* Sub tabs switcher - Modern iOS/Android Segmented Control */}
      <div className="flex bg-slate-100 p-1 rounded-2xl gap-1 max-w-2xl mx-auto mb-6 border border-slate-200/50">
        <button
          onClick={() => setActiveSubTab('popular')}
          className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-2 text-xs font-black rounded-xl transition-all cursor-pointer ${
            activeSubTab === 'popular'
              ? 'bg-white text-indigo-600 shadow-md border border-slate-200/20'
              : 'text-slate-600 hover:text-indigo-600 hover:bg-white/50'
          }`}
        >
          <span className="text-sm">🛤️</span>
          <span className="hidden md:inline">{language === 'en' ? 'Direct Routes' : 'सीधे मार्ग'}</span>
          <span className="md:hidden">{language === 'en' ? 'Routes' : 'मार्ग'}</span>
        </button>
        <button
          onClick={() => setActiveSubTab('status')}
          className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-2 text-xs font-black rounded-xl transition-all cursor-pointer ${
            activeSubTab === 'status'
              ? 'bg-white text-indigo-600 shadow-md border border-slate-200/20'
              : 'text-slate-600 hover:text-indigo-600 hover:bg-white/50'
          }`}
        >
          <span className="text-sm">📍</span>
          <span className="hidden md:inline">{language === 'en' ? 'Spot Train' : 'स्पॉट ट्रेन'}</span>
          <span className="md:hidden">{language === 'en' ? 'Spot' : 'स्पॉट'}</span>
        </button>
        <button
          onClick={() => setActiveSubTab('pnr')}
          className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-2 text-xs font-black rounded-xl transition-all cursor-pointer ${
            activeSubTab === 'pnr'
              ? 'bg-white text-indigo-600 shadow-md border border-slate-200/20'
              : 'text-slate-600 hover:text-indigo-600 hover:bg-white/50'
          }`}
        >
          <span className="text-sm">🔍</span>
          <span>{language === 'en' ? 'PNR Status' : 'पीएनआर'}</span>
        </button>
        <button
          onClick={() => {
            setActiveSubTab('book');
            setBookedTicket(null);
          }}
          className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-2 text-xs font-black rounded-xl transition-all cursor-pointer ${
            activeSubTab === 'book'
              ? 'bg-white text-indigo-600 shadow-md border border-slate-200/20'
              : 'text-slate-600 hover:text-indigo-600 hover:bg-white/50'
          }`}
        >
          <span className="text-sm">🎫</span>
          <span>{language === 'en' ? 'Tickets' : 'टिकट'}</span>
        </button>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Left Column - Input Panel */}
        <div className="lg:col-span-1 space-y-4">
          {activeSubTab === 'status' && (
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm space-y-4">
              <h3 className="text-sm font-black text-slate-800">
                {language === 'en' ? 'Enter Train Details' : 'ट्रेन विवरण दर्ज करें'}
              </h3>
              <div className="space-y-3">
                <div className="relative">
                  <input
                    type="text"
                    value={trainNo}
                    onChange={(e) => setTrainNo(e.target.value)}
                    placeholder={language === 'en' ? 'e.g., 11110 or Bundelkhand' : 'जैसे, 11110 या बुंदेलखंड'}
                    className="w-full px-4 py-3 pl-11 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:outline-none focus:border-indigo-500 font-bold"
                  />
                  <Search className="absolute left-3.5 top-3.5 h-4 w-4 text-slate-400" />
                </div>
                <button
                  onClick={() => handleSearchStatus(trainNo)}
                  className="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-black rounded-2xl shadow-md transition active:scale-95 cursor-pointer"
                >
                  {language === 'en' ? 'Fetch Running Status' : 'रनिंग स्टेटस प्राप्त करें'}
                </button>
              </div>
            </div>
          )}

          {activeSubTab === 'book' && (
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm space-y-4">
              <h3 className="text-sm font-black text-slate-800 flex items-center gap-2 border-b border-slate-100 pb-2">
                <Ticket className="h-4 w-4 text-indigo-600" />
                <span>{language === 'en' ? 'Book Train Tickets' : 'ट्रेन टिकट बुक करें'}</span>
              </h3>

              {recentRoutes.length > 0 && (
                <div className="space-y-1.5 pb-2 border-b border-slate-100">
                  <span className="text-[10px] font-black text-slate-400 uppercase tracking-wider block">
                    {language === 'en' ? '🕒 Recent Searches' : '🕒 हाल की खोजें'}
                  </span>
                  <div className="flex flex-wrap gap-1.5">
                    {recentRoutes.map((route, idx) => (
                      <button
                        key={idx}
                        type="button"
                        onClick={() => handleSelectRecentRoute(route)}
                        className="inline-flex items-center gap-1 px-2.5 py-1 bg-slate-50 hover:bg-indigo-50 border border-slate-100 hover:border-indigo-100 rounded-lg text-[10px] font-bold text-slate-600 hover:text-indigo-600 transition cursor-pointer"
                        title={`${route.from} ➔ ${route.to}`}
                      >
                        <span className="truncate max-w-[80px]">{route.from.split('(')[0].trim()}</span>
                        <span className="text-slate-400 font-normal">➔</span>
                        <span className="truncate max-w-[80px]">{route.to.split('(')[0].trim()}</span>
                      </button>
                    ))}
                  </div>
                </div>
              )}

              <form onSubmit={handleSearchBookings} className="space-y-4">
                {/* From Station */}
                <div>
                  <label className="text-[10px] font-black text-slate-400 uppercase tracking-wider block mb-1">
                    {language === 'en' ? 'From Station' : 'कहाँ से'}
                  </label>
                  <input
                    type="text"
                    required
                    value={fromStation}
                    onChange={(e) => setFromStation(e.target.value)}
                    placeholder="e.g. Ragaul (RGU), Delhi, Mumbai"
                    className="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold focus:outline-none focus:border-indigo-500"
                  />
                </div>

                {/* To Station */}
                <div>
                  <label className="text-[10px] font-black text-slate-400 uppercase tracking-wider block mb-1">
                    {language === 'en' ? 'To Station' : 'कहाँ तक'}
                  </label>
                  <input
                    type="text"
                    required
                    value={toStation}
                    onChange={(e) => setToStation(e.target.value)}
                    placeholder="e.g. Kanpur Central, Banda, Lucknow"
                    className="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold focus:outline-none focus:border-indigo-500"
                  />
                </div>

                {/* Travel Date */}
                <div>
                  <label className="text-[10px] font-black text-slate-400 uppercase tracking-wider block mb-1">
                    {language === 'en' ? 'Travel Date' : 'यात्रा की तारीख'}
                  </label>
                  <input
                    type="date"
                    required
                    value={bookingDate}
                    onChange={(e) => setBookingDate(e.target.value)}
                    className="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold focus:outline-none focus:border-indigo-500"
                  />
                </div>

                {/* Passenger Name */}
                <div>
                  <label className="text-[10px] font-black text-slate-400 uppercase tracking-wider block mb-1">
                    {language === 'en' ? 'Passenger Name' : 'यात्री का नाम'}
                  </label>
                  <input
                    type="text"
                    required
                    placeholder={currentUser?.name || "e.g. Rajesh Kumar"}
                    value={passenger}
                    onChange={(e) => setPassenger(e.target.value)}
                    className="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs font-bold focus:outline-none focus:border-indigo-500"
                  />
                </div>

                <button
                  type="submit"
                  className="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-black rounded-2xl shadow-md transition active:scale-95 cursor-pointer"
                >
                  {language === 'en' ? 'Search Trains' : 'ट्रेनें खोजें'}
                </button>
              </form>
            </div>
          )}

          {activeSubTab === 'pnr' && (
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm space-y-4">
              <h3 className="text-sm font-black text-slate-800">
                {language === 'en' ? 'Passenger Name Record (PNR)' : 'यात्री नाम रिकॉर्ड (पीएनआर)'}
              </h3>
              <div className="space-y-3">
                <input
                  type="text"
                  maxLength={10}
                  value={pnrNo}
                  onChange={(e) => setPnrNo(e.target.value)}
                  placeholder={language === 'en' ? 'Enter 10-digit PNR Number' : '10 अंकों का पीएनआर नंबर डालें'}
                  className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:outline-none focus:border-indigo-500 font-mono font-bold tracking-widest text-center"
                />
                {errorMsg && (
                  <div className="flex items-center gap-1.5 text-xs text-rose-600 font-bold">
                    <AlertCircle className="h-3.5 w-3.5" />
                    <span>{errorMsg}</span>
                  </div>
                )}
                <button
                  onClick={handlePnrCheck}
                  className="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-black rounded-2xl shadow-md transition active:scale-95 cursor-pointer"
                >
                  {language === 'en' ? 'Check Booking Status' : 'बुकिंग स्थिति जांचें'}
                </button>
              </div>
            </div>
          )}

          {/* Quick list of direct trains */}
          <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm space-y-3">
            <h3 className="text-xs font-black text-slate-400 uppercase tracking-wider select-none">
              {language === 'en' ? 'Frequent Ragaul Trains' : 'अक्सर रागौल आने वाली ट्रेनें'}
            </h3>
            <div className="space-y-2">
              {POPULAR_TRAINS.map((t) => (
                <button
                  key={t.number}
                  onClick={() => {
                    setActiveSubTab('status');
                    setTrainNo(t.number);
                    handleSearchStatus(t.number);
                  }}
                  className="w-full flex items-center justify-between p-3 hover:bg-indigo-50/50 border border-slate-50 hover:border-indigo-100 rounded-2xl transition text-left cursor-pointer group"
                >
                  <div>
                    <span className="text-xs font-black text-slate-700 block group-hover:text-indigo-600">
                      {language === 'en' ? t.name : t.nameHi}
                    </span>
                    <span className="text-[10px] text-slate-400 font-bold block">
                      No: {t.number} • {t.time}
                    </span>
                  </div>
                  <ArrowRight className="h-4 w-4 text-slate-300 group-hover:text-indigo-500 group-hover:translate-x-1 transition" />
                </button>
              ))}
            </div>
          </div>

          {/* History / Saved Queries */}
          {savedQueries.length > 0 && (
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm space-y-3">
              <h3 className="text-xs font-black text-slate-400 uppercase tracking-wider select-none">
                {language === 'en' ? 'Recent Enquiries' : 'हाल ही में की गई पूछताछ'}
              </h3>
              <div className="space-y-2 max-h-48 overflow-y-auto scrollbar-none">
                {savedQueries.map((q) => (
                  <div
                    key={q.id}
                    className="flex items-center justify-between p-2.5 bg-slate-50 border border-slate-100 rounded-xl"
                  >
                    <button
                      onClick={() => {
                        setActiveSubTab('status');
                        setTrainNo(q.trainNumber);
                        handleSearchStatus(q.trainNumber);
                      }}
                      className="text-left cursor-pointer flex-1"
                    >
                      <span className="text-[11px] font-black text-slate-700 block">
                        {q.trainNumber} - {q.trainName}
                      </span>
                      <span className="text-[9px] text-indigo-600 font-bold block">
                        {language === 'en' ? q.statusText : q.statusTextHi}
                      </span>
                    </button>
                    <button
                      onClick={() => handleDeleteQuery(q.id)}
                      className="p-1 text-slate-300 hover:text-rose-600 rounded-lg transition cursor-pointer"
                    >
                      <Trash2 className="h-3.5 w-3.5" />
                    </button>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Recent Searched Routes (Durable list) */}
          {recentRoutes.length > 0 && (
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm space-y-3">
              <div className="flex items-center justify-between border-b border-slate-100 pb-2">
                <h3 className="text-xs font-black text-slate-400 uppercase tracking-wider select-none flex items-center gap-1.5">
                  <span className="p-1 bg-indigo-50 text-indigo-600 rounded-lg">⏱️</span>
                  <span>{language === 'en' ? 'Recent Stations' : 'हाल के स्टेशन'}</span>
                </h3>
                <button
                  onClick={handleClearRecentRoutes}
                  className="text-[10px] font-bold text-rose-500 hover:text-rose-700 hover:bg-rose-50 px-2 py-1 rounded-lg cursor-pointer transition"
                >
                  {language === 'en' ? 'Clear All' : 'सभी हटाएं'}
                </button>
              </div>
              <div className="space-y-2 max-h-56 overflow-y-auto scrollbar-none">
                {recentRoutes.map((route, idx) => (
                  <button
                    key={idx}
                    onClick={() => {
                      setActiveSubTab('book');
                      handleSelectRecentRoute(route);
                    }}
                    className="w-full flex items-center justify-between p-2.5 bg-slate-50/50 hover:bg-indigo-50/50 border border-slate-100/70 hover:border-indigo-100 rounded-xl transition text-left cursor-pointer group"
                  >
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-1 text-xs font-black text-slate-700 group-hover:text-indigo-600 truncate">
                        <span className="truncate max-w-[90px]" title={route.from}>{route.from.split('(')[0].trim()}</span>
                        <span className="text-indigo-500 font-normal">↔</span>
                        <span className="truncate max-w-[90px]" title={route.to}>{route.to.split('(')[0].trim()}</span>
                      </div>
                      <span className="text-[9px] text-slate-400 font-bold block mt-0.5">
                        {language === 'en' ? 'Tap to search this route again' : 'इस मार्ग को पुनः खोजने के लिए टैप करें'}
                      </span>
                    </div>
                    <ArrowRight className="h-3.5 w-3.5 text-slate-300 group-hover:text-indigo-500 group-hover:translate-x-1 transition shrink-0 ml-1" />
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* Right Column - Rich Output / Status Displays */}
        <div className="lg:col-span-2 space-y-4">
          {activeSubTab === 'popular' && !searchResult && !pnrResult && (
            <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6">
              <h3 className="text-base font-black text-slate-800 border-b border-slate-100 pb-3 flex items-center gap-2">
                <span className="p-1 bg-indigo-50 text-indigo-600 rounded-lg">🛤️</span>
                <span>{language === 'en' ? 'Direct Routes via Ragaul Station' : 'रागौल स्टेशन के रास्ते सीधे मार्ग'}</span>
              </h3>

              <div className="space-y-4">
                {POPULAR_TRAINS.map((train) => (
                  <div key={train.number} className="p-4 border border-slate-100 rounded-2xl hover:border-indigo-100 hover:shadow-sm transition space-y-3">
                    <div className="flex justify-between items-start">
                      <div>
                        <span className="px-2 py-0.5 bg-indigo-50 text-indigo-700 text-[10px] font-black rounded-lg">
                          {train.number}
                        </span>
                        <h4 className="text-sm font-black text-slate-800 mt-1">
                          {language === 'en' ? train.name : train.nameHi}
                        </h4>
                        <p className="text-xs font-bold text-slate-500">
                          {language === 'en' ? train.route : train.routeHi}
                        </p>
                      </div>
                      <span className="text-xs font-black text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-xl">
                        {language === 'en' ? train.status : train.statusHi}
                      </span>
                    </div>

                    <div className="flex items-center gap-4 text-xs font-bold text-slate-600 pt-2 border-t border-slate-50">
                      <span className="flex items-center gap-1">
                        <Clock className="h-3.5 w-3.5 text-slate-400" />
                        <span>MXM Station Arrival: {train.time}</span>
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Running Status Render */}
          {activeSubTab === 'status' && searchResult && (
            <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6 animate-in fade-in duration-300">
              <div className="flex flex-col sm:flex-row justify-between items-start gap-4 border-b border-slate-100 pb-4">
                <div>
                  <span className="text-xs font-black text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded-xl">
                    Train Live Status
                  </span>
                  <h3 className="text-base font-black text-slate-800 mt-2">
                    {searchResult.number} - {language === 'en' ? searchResult.name : searchResult.nameHi}
                  </h3>
                  <p className="text-xs font-bold text-slate-500">
                    {language === 'en' ? searchResult.route : searchResult.routeHi}
                  </p>
                </div>
                <div className="text-right sm:text-right">
                  <span className="text-xs font-black text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-xl block">
                    {language === 'en' ? searchResult.status : searchResult.statusHi}
                  </span>
                  <span className="text-[11px] text-slate-400 font-black mt-1 block">
                    Delay: {language === 'en' ? searchResult.delay : searchResult.delayHi}
                  </span>
                </div>
              </div>

              {/* Route Progress Visual Map */}
              {(() => {
                const stations = searchResult.stations || [];
                if (stations.length === 0) return null;

                const activeIdx = stations.findIndex((st: any) => st.status === 'active');
                const departedCount = stations.filter((st: any) => st.status === 'departed').length;

                let progressPercent = 0;
                if (activeIdx !== -1) {
                  progressPercent = (activeIdx / (stations.length - 1)) * 100;
                } else if (departedCount === stations.length) {
                  progressPercent = 100;
                } else if (departedCount > 0) {
                  progressPercent = ((departedCount - 0.5) / (stations.length - 1)) * 100;
                }

                const firstStationName = language === 'en' ? stations[0].name : stations[0].nameHi;
                const lastStationName = language === 'en' ? stations[stations.length - 1].name : stations[stations.length - 1].nameHi;
                const currentStationName = activeIdx !== -1 
                  ? (language === 'en' ? stations[activeIdx].name : stations[activeIdx].nameHi)
                  : (departedCount === stations.length 
                      ? (language === 'en' ? 'Arrived' : 'पहुंच गई') 
                      : (language === 'en' ? 'Yet to Start' : 'शुरू नहीं हुई'));

                return (
                  <div className="p-4 bg-slate-50/80 border border-slate-100 rounded-2xl space-y-4">
                    <div className="flex justify-between items-center">
                      <span className="text-[11px] font-black text-slate-400 uppercase tracking-wider flex items-center gap-1.5">
                        <MapPin className="h-3.5 w-3.5 text-indigo-500" />
                        {language === 'en' ? 'Route Progress Map' : 'मार्ग प्रगति मानचित्र'}
                      </span>
                      <span className="text-[11px] font-black text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-md">
                        {progressPercent === 100 
                          ? (language === 'en' ? 'Completed' : 'पूर्ण') 
                          : `${Math.round(progressPercent)}% ${language === 'en' ? 'Completed' : 'पूर्ण'}`}
                      </span>
                    </div>

                    {/* The Track Container */}
                    <div className="relative pt-6 pb-2 px-1">
                      {/* Grey Base Track */}
                      <div className="absolute top-8 left-0 right-0 h-1.5 bg-slate-200 rounded-full" />

                      {/* Colored Progress Fill */}
                      <div 
                        className="absolute top-8 left-0 h-1.5 bg-gradient-to-r from-emerald-500 to-indigo-600 rounded-full transition-all duration-500 ease-out"
                        style={{ width: `${progressPercent}%` }}
                      />

                      {/* Train Indicator Pin */}
                      <div 
                        className="absolute top-3 -mt-1.5 transition-all duration-500 ease-out -translate-x-1/2 flex flex-col items-center z-10"
                        style={{ left: `${progressPercent}%` }}
                      >
                        <div className="bg-indigo-600 text-white p-1 rounded-full shadow-md animate-bounce ring-4 ring-indigo-50">
                          <Train className="h-3.5 w-3.5" />
                        </div>
                        <div className="w-1.5 h-1.5 bg-indigo-600 rounded-full mt-0.5" />
                      </div>

                      {/* Station Node Dots */}
                      <div className="absolute top-8 left-0 right-0 flex justify-between pointer-events-none">
                        {stations.map((st: any, idx: number) => {
                          const isStActive = st.status === 'active';
                          const isStDeparted = st.status === 'departed';
                          const pct = (idx / (stations.length - 1)) * 100;
                          
                          return (
                            <div 
                              key={idx} 
                              className="absolute -translate-x-1/2 -translate-y-1/2 flex flex-col items-center"
                              style={{ left: `${pct}%`, top: '0px' }}
                            >
                              <div className={`h-2.5 w-2.5 rounded-full border-2 transition-all duration-300 ${
                                isStActive 
                                  ? 'bg-indigo-600 border-white scale-125 ring-2 ring-indigo-200 ring-offset-1' 
                                  : isStDeparted 
                                    ? 'bg-emerald-500 border-white' 
                                    : 'bg-slate-300 border-white'
                              }`} />
                            </div>
                          );
                        })}
                      </div>
                    </div>

                    {/* Source, Active, and Destination Station Labels */}
                    <div className="grid grid-cols-3 gap-2 pt-2 text-[10px] font-black text-slate-500">
                      <div className="text-left truncate">
                        <span className="block text-[8px] text-slate-400 uppercase tracking-wider">
                          {language === 'en' ? 'Origin' : 'प्रस्थान'}
                        </span>
                        <span className="text-slate-700 truncate block max-w-full font-bold">
                          {firstStationName.split('(')[0].trim()}
                        </span>
                      </div>
                      <div className="text-center truncate">
                        <span className="block text-[8px] text-indigo-500 uppercase tracking-wider">
                          {language === 'en' ? 'Current Position' : 'वर्तमान स्थिति'}
                        </span>
                        <span className="text-indigo-600 font-bold truncate block max-w-full">
                          {currentStationName.split('(')[0].trim()}
                        </span>
                      </div>
                      <div className="text-right truncate">
                        <span className="block text-[8px] text-slate-400 uppercase tracking-wider">
                          {language === 'en' ? 'Destination' : 'गंतव्य'}
                        </span>
                        <span className="text-slate-700 truncate block max-w-full font-bold">
                          {lastStationName.split('(')[0].trim()}
                        </span>
                      </div>
                    </div>
                  </div>
                );
              })()}

              {/* Next Arriving Station expected platform and info badge */}
              {(() => {
                const stations = searchResult.stations || [];
                const activeIdx = stations.findIndex((st: any) => st.status === 'active');
                let nextArrivingStation: any = null;

                if (activeIdx !== -1 && activeIdx + 1 < stations.length) {
                  nextArrivingStation = stations[activeIdx + 1];
                } else if (activeIdx === -1) {
                  nextArrivingStation = stations.find((st: any) => st.status === 'upcoming');
                }

                if (!nextArrivingStation) return null;

                return (
                  <div className="p-4 bg-gradient-to-r from-indigo-50/70 via-indigo-50/30 to-slate-50/50 border border-indigo-100 rounded-2xl flex items-center justify-between gap-4 animate-in fade-in duration-300">
                    <div className="flex items-center gap-3">
                      <div className="p-2.5 bg-indigo-600 text-white rounded-xl shadow-md shrink-0">
                        <MapPin className="h-5 w-5 animate-pulse" />
                      </div>
                      <div>
                        <span className="text-[10px] font-black text-indigo-600 uppercase tracking-wider block">
                          {language === 'en' ? 'Next Arriving Station' : 'अगला स्टेशन आगमन'}
                        </span>
                        <h4 className="text-sm font-black text-slate-800 mt-0.5">
                          {language === 'en' ? nextArrivingStation.name : nextArrivingStation.nameHi}
                        </h4>
                        <p className="text-[11px] font-bold text-slate-500">
                          {language === 'en' ? `Expected Arrival: ${nextArrivingStation.time}` : `अपेक्षित आगमन: ${nextArrivingStation.time}`}
                        </p>
                      </div>
                    </div>
                    
                    <div className="bg-white px-3.5 py-1.5 border border-indigo-100/80 rounded-xl text-center shadow-sm shrink-0">
                      <span className="text-[9px] font-black text-slate-400 block uppercase tracking-wider">
                        {language === 'en' ? 'Platform' : 'प्लेटफार्म'}
                      </span>
                      <span className="text-sm font-black text-indigo-600 font-mono">
                        PF {getExpectedPlatform(searchResult.number, nextArrivingStation.name)}
                      </span>
                    </div>
                  </div>
                );
              })()}

              {/* Station timeline running trail */}
              <div className="relative pl-14 pr-1 py-4 space-y-8">
                {/* Visual Steel Tracks and Wooden Sleepers */}
                <div 
                  className="absolute left-[24px] top-4 bottom-4 w-5 pointer-events-none rounded-full overflow-hidden border-l border-r border-slate-300"
                  style={{
                    background: 'repeating-linear-gradient(to bottom, #f8fafc, #f8fafc 12px, #854d0e 12px, #854d0e 15px)',
                    boxShadow: 'inset 1px 0 3px rgba(0,0,0,0.05)'
                  }}
                >
                  {/* Left steel rail line */}
                  <div className="absolute left-0.5 top-0 bottom-0 w-[2px] bg-gradient-to-r from-slate-400 to-slate-200 shadow-sm" />
                  {/* Right steel rail line */}
                  <div className="absolute right-0.5 top-0 bottom-0 w-[2px] bg-gradient-to-r from-slate-400 to-slate-200 shadow-sm" />
                </div>

                {searchResult.stations.map((st: any, idx: number) => {
                  const isActive = st.status === 'active';
                  const isDeparted = st.status === 'departed';
                  return (
                    <div key={idx} className="relative group">
                      {/* Node Indicator on the track */}
                      <span className="absolute left-[-42px] top-1.5 z-20 flex items-center justify-center w-[36px] h-[36px]">
                        {isActive ? (
                          <div className="relative flex items-center justify-center">
                            {/* Glowing effect */}
                            <span className="absolute inline-flex h-9 w-9 animate-ping rounded-full bg-indigo-400 opacity-40" />
                            <div className="relative bg-gradient-to-br from-indigo-600 to-indigo-700 text-white p-2 rounded-full shadow-lg border-2 border-white z-30 transition transform scale-110">
                              <Train className="h-4 w-4 animate-pulse" />
                            </div>
                          </div>
                        ) : isDeparted ? (
                          <div className="h-4.5 w-4.5 bg-emerald-500 border-4 border-white rounded-full flex items-center justify-center shadow-md z-10 transition group-hover:scale-110">
                            <span className="h-1 w-1 rounded-full bg-white block" />
                          </div>
                        ) : (
                          <div className="h-4.5 w-4.5 bg-slate-300 border-4 border-white rounded-full flex items-center justify-center shadow-sm z-10 transition group-hover:scale-110 group-hover:bg-indigo-400" />
                        )}
                      </span>

                      {/* Station Details Card */}
                      <div className={`p-4 rounded-2xl border transition-all ${
                        isActive 
                          ? 'bg-gradient-to-r from-indigo-50/60 to-white border-indigo-200/80 shadow-md ring-1 ring-indigo-100' 
                          : isDeparted 
                            ? 'bg-slate-50/50 border-slate-100 hover:border-slate-200' 
                            : 'bg-white border-slate-100 hover:border-slate-200 shadow-sm'
                      }`}>
                        <div className="flex justify-between items-start gap-2">
                          <div>
                            <div className="flex items-center gap-2">
                              <h4 className={`text-sm font-black transition ${
                                isActive ? 'text-indigo-900 text-base' : isDeparted ? 'text-slate-500' : 'text-slate-800'
                              }`}>
                                {language === 'en' ? st.name : st.nameHi}
                              </h4>
                              {isActive && (
                                <span className="px-2 py-0.5 bg-indigo-100 text-indigo-700 text-[9px] font-black rounded-lg animate-pulse">
                                  {language === 'en' ? 'CURRENT LOCATION' : 'वर्तमान स्थिति'}
                                </span>
                              )}
                            </div>

                            <div className="flex flex-wrap items-center gap-x-2.5 gap-y-1 mt-1 text-xs">
                              <span className="text-slate-400 font-bold flex items-center gap-1">
                                <Clock className="h-3 w-3" />
                                {language === 'en' ? `Scheduled Stop: ${st.time}` : `निर्धारित स्टॉप: ${st.time}`}
                              </span>
                              
                              <span className="text-slate-300">•</span>
                              
                              {/* Expected Platform */}
                              <span className="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-400 text-slate-900 border border-amber-500/30 rounded text-[10px] font-black tracking-wider shadow-sm">
                                PF {getExpectedPlatform(searchResult.number, st.name)}
                              </span>

                              {/* Delay Status */}
                              {(() => {
                                const isLate = searchResult.delay && searchResult.delay !== 'No delay' && searchResult.delay !== 'कोई देरी नहीं';
                                return (
                                  <>
                                    <span className="text-slate-300">•</span>
                                    <span className={`font-black text-[10px] uppercase tracking-wider ${isLate ? 'text-rose-600' : 'text-emerald-600'}`}>
                                      {isLate 
                                        ? (language === 'en' ? `Late ${searchResult.delay}` : `${searchResult.delay} देरी`) 
                                        : (language === 'en' ? 'On Time' : 'समय पर')}
                                    </span>
                                  </>
                                );
                              })()}
                            </div>
                          </div>

                          <span className={`text-[10px] font-black uppercase tracking-wider px-2.5 py-1 rounded-xl shadow-sm border ${
                            isDeparted 
                              ? 'text-slate-400 bg-slate-50 border-slate-100' 
                              : isActive 
                                ? 'text-indigo-700 bg-indigo-50 border-indigo-100' 
                                : 'text-slate-600 bg-slate-100 border-slate-200/50'
                          }`}>
                            {isActive 
                              ? (language === 'en' ? 'Halted' : 'रुकी हुई')
                              : isDeparted 
                                ? (language === 'en' ? 'Passed' : 'गुजरी') 
                                : (language === 'en' ? 'Upcoming' : 'आने वाली')}
                          </span>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>

              <div className="flex items-center gap-2 p-3 bg-amber-50 border border-amber-200 rounded-2xl text-xs text-amber-800 font-bold">
                <AlertCircle className="h-4 w-4 text-amber-600 shrink-0" />
                <span>
                  {language === 'en' 
                    ? 'Note: Train status simulation is running locally. Check terminal monitors at Ragaul Station for exact track assignments.'
                    : 'नोट: ट्रेन की स्थिति का सिमुलेशन स्थानीय रूप से चल रहा है। सटीक ट्रैक आवंटन के लिए रागौल स्टेशन पर टर्मिनल मॉनिटर की जांच करें।'}
                </span>
              </div>
            </div>
          )}

          {/* PNR Status Render */}
          {activeSubTab === 'pnr' && pnrResult && (
            <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6 animate-in fade-in duration-300">
              <div className="border-b border-slate-100 pb-4">
                <span className="text-xs font-black text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded-xl">
                  PNR Reservation Status
                </span>
                <div className="flex justify-between items-center mt-3">
                  <h3 className="text-base font-black text-slate-800">
                    PNR: {pnrResult.pnr}
                  </h3>
                  <span className="text-xs font-black text-slate-400">
                    Date of Journey: {language === 'en' ? pnrResult.date : pnrResult.dateHi}
                  </span>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-4">
                <div className="p-3 bg-slate-50 rounded-2xl border border-slate-100">
                  <span className="text-[10px] font-black text-slate-400 block uppercase">Train Info</span>
                  <span className="text-xs font-black text-slate-700">{language === 'en' ? pnrResult.train : pnrResult.trainHi}</span>
                </div>
                <div className="p-3 bg-slate-50 rounded-2xl border border-slate-100">
                  <span className="text-[10px] font-black text-slate-400 block uppercase">Boarding Terminal</span>
                  <span className="text-xs font-black text-slate-700">{pnrResult.from}</span>
                </div>
              </div>

              <div className="space-y-3">
                <h4 className="text-xs font-black text-slate-400 uppercase tracking-wider">Passenger Bookings</h4>
                <div className="space-y-2">
                  {pnrResult.passengers.map((passenger: any, idx: number) => (
                    <div key={idx} className="flex justify-between items-center p-3 border border-slate-100 rounded-2xl">
                      <div>
                        <span className="text-xs font-black text-slate-800 block">{passenger.name}</span>
                        <span className="text-[11px] text-slate-500 font-bold block">Seat: {passenger.seat}</span>
                      </div>
                      <span className="flex items-center gap-1.5 text-xs font-black text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-xl">
                        <CheckCircle className="h-3.5 w-3.5 text-emerald-500" />
                        <span>{passenger.status}</span>
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {/* Train Booking Search Results */}
          {activeSubTab === 'book' && searchedBookings && !selectedTrain && !bookedTicket && (
            <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6 animate-in fade-in duration-300">
              <div className="flex justify-between items-center border-b border-slate-100 pb-4">
                <div>
                  <span className="text-xs font-black text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded-xl">
                    {language === 'en' ? 'Available Trains Found' : 'उपलब्ध ट्रेनें मिलीं'}
                  </span>
                  <h3 className="text-base font-black text-slate-800 mt-2">
                    {fromStation} ➔ {toStation}
                  </h3>
                  <p className="text-xs font-bold text-slate-500 mt-1">
                    {language === 'en' ? `Date of Journey: ${bookingDate}` : `यात्रा की तारीख: ${bookingDate}`}
                  </p>
                </div>
                <button
                  onClick={() => setSearchedBookings(false)}
                  className="px-3 py-1.5 border border-slate-200 text-slate-600 hover:bg-slate-50 text-[11px] font-black rounded-xl transition cursor-pointer"
                >
                  {language === 'en' ? 'Change Search' : 'खोज बदलें'}
                </button>
              </div>

              <div className="space-y-4">
                {getMockTrains().map((train) => {
                  const classObj = COACH_CLASSES.find(c => c.code === selectedClass);
                  const classBase = classObj ? classObj.basePrice : 480;
                  const subtotal = train.basePrice + classBase;
                  const adminProfit = Math.round(subtotal * 0.02);
                  const totalPrice = subtotal + adminProfit;

                  return (
                    <div key={train.number} className="p-4 border border-slate-100 hover:border-indigo-100 rounded-2xl hover:shadow-sm transition space-y-3">
                      <div className="flex flex-col sm:flex-row justify-between items-start gap-2">
                        <div>
                          <div className="flex items-center gap-2">
                            <span className="px-2 py-0.5 bg-indigo-50 text-indigo-700 text-[10px] font-black rounded-lg">
                              {train.number}
                            </span>
                            <span className="text-xs text-slate-400 font-bold">
                              {language === 'en' ? `Runs: ${train.runsOn}` : `संचालन: ${train.runsOn}`}
                            </span>
                          </div>
                          <h4 className="text-sm font-black text-slate-800 mt-1">
                            {language === 'en' ? train.name : train.nameHi}
                          </h4>
                        </div>
                        <div className="text-left sm:text-right">
                          <span className="text-xs text-slate-400 font-bold block">
                            {language === 'en' ? 'Estimated Duration' : 'अनुमानित समय'}
                          </span>
                          <span className="text-xs font-black text-indigo-600">
                            {train.duration}
                          </span>
                        </div>
                      </div>

                      {/* Journey Timings */}
                      <div className="flex items-center gap-6 py-2 border-t border-b border-slate-50 text-xs">
                        <div>
                          <span className="text-[10px] text-slate-400 font-bold block uppercase">{language === 'en' ? 'Departure' : 'प्रस्थान'}</span>
                          <span className="font-black text-slate-700">{train.departureTime}</span>
                          <span className="text-[10px] text-slate-400 font-medium block">{fromStation}</span>
                        </div>
                        <ArrowRight className="h-4 w-4 text-slate-300" />
                        <div>
                          <span className="text-[10px] text-slate-400 font-bold block uppercase">{language === 'en' ? 'Arrival' : 'आगमन'}</span>
                          <span className="font-black text-slate-700">{train.arrivalTime}</span>
                          <span className="text-[10px] text-slate-400 font-medium block">{toStation}</span>
                        </div>
                      </div>

                      {/* Ticket Classes Selection */}
                      <div>
                        <span className="text-[10px] font-black text-slate-400 uppercase tracking-wider block mb-2">
                          {language === 'en' ? 'Select Ticket Class' : 'टिकट श्रेणी चुनें'}
                        </span>
                        <div className="grid grid-cols-2 sm:grid-cols-4 gap-2">
                          {COACH_CLASSES.map((cls) => {
                            const clsSub = train.basePrice + cls.basePrice;
                            const clsProf = Math.round(clsSub * 0.02);
                            const clsTotal = clsSub + clsProf;
                            const isSelected = selectedClass === cls.code;

                            return (
                              <button
                                key={cls.code}
                                type="button"
                                onClick={() => setSelectedClass(cls.code as any)}
                                className={`p-2.5 rounded-xl border text-left transition cursor-pointer ${
                                  isSelected
                                    ? 'border-indigo-600 bg-indigo-50/50 shadow-sm'
                                    : 'border-slate-100 bg-slate-50/50 hover:bg-slate-50'
                                }`}
                              >
                                <span className="text-[11px] font-black text-slate-700 block">
                                  {cls.code}
                                </span>
                                <span className="text-[9px] text-slate-400 font-bold block leading-none mb-1">
                                  {language === 'en' ? cls.name.split(' ')[0] : cls.nameHi.split(' ')[0]}
                                </span>
                                <span className="text-xs font-black text-indigo-700 block">
                                  ₹{clsTotal}
                                </span>
                              </button>
                            );
                          })}
                        </div>
                      </div>

                      {/* Select Train Button */}
                      <div className="flex justify-between items-center pt-2 border-t border-slate-50">
                        <div>
                          <span className="text-[10px] text-slate-400 font-bold block">{language === 'en' ? 'Grand Total' : 'कुल किराया'}</span>
                          <span className="text-base font-black text-slate-800">₹{totalPrice}</span>
                        </div>
                        <button
                          onClick={() => {
                            setSelectedTrain(train);
                            setShowPaymentGateway(true);
                          }}
                          className="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-black rounded-xl shadow-md transition active:scale-95 cursor-pointer flex items-center gap-1"
                        >
                          <Ticket className="h-3.5 w-3.5" />
                          <span>{language === 'en' ? 'Proceed to Pay' : 'भुगतान के लिए आगे बढ़ें'}</span>
                        </button>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          {/* Checkout & Secure Payment Gate */}
          {activeSubTab === 'book' && selectedTrain && !bookedTicket && (
            <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-6 animate-in fade-in duration-300">
              <div className="flex justify-between items-center border-b border-slate-100 pb-4">
                <div>
                  <span className="text-xs font-black text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded-xl">
                    Secure Ticket Checkout
                  </span>
                  <h3 className="text-base font-black text-slate-800 mt-2">
                    {selectedTrain.number} - {language === 'en' ? selectedTrain.name : selectedTrain.nameHi}
                  </h3>
                </div>
                <button
                  onClick={() => {
                    setSelectedTrain(null);
                    setShowPaymentGateway(false);
                  }}
                  className="px-3 py-1.5 border border-slate-200 text-slate-600 hover:bg-slate-50 text-[11px] font-black rounded-xl transition cursor-pointer"
                >
                  {language === 'en' ? 'Back' : 'पीछे'}
                </button>
              </div>

              {/* Passenger & Berth Preference Summary */}
              <div className="p-4 bg-slate-50/70 border border-slate-100 rounded-2xl space-y-3">
                <h4 className="text-xs font-black text-slate-400 uppercase tracking-wider">{language === 'en' ? 'Passenger Details' : 'यात्री विवरण'}</h4>
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <span className="text-[10px] text-slate-400 font-bold block">{language === 'en' ? 'Name' : 'नाम'}</span>
                    <span className="text-xs font-black text-slate-700">{passenger.trim() || currentUser?.name || 'Guest Passenger'}</span>
                  </div>
                  <div>
                    <span className="text-[10px] text-slate-400 font-bold block">{language === 'en' ? 'Class' : 'श्रेणी'}</span>
                    <span className="text-xs font-black text-slate-700">
                      {COACH_CLASSES.find(c => c.code === selectedClass)?.name || 'AC 3 Tier (3A)'}
                    </span>
                  </div>
                  <div>
                    <span className="text-[10px] text-slate-400 font-bold block">{language === 'en' ? 'Select Preferred Berth' : 'पसंदीदा बर्थ चुनें'}</span>
                    <select
                      value={selectedSeat || ''}
                      onChange={(e) => setSelectedSeat(e.target.value)}
                      className="mt-1 block w-full px-2 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-bold text-slate-700 focus:outline-none focus:border-indigo-500"
                    >
                      <option value="">{language === 'en' ? 'Random Assignment (Recommended)' : 'यादृच्छिक आवंटन (अनुशंसित)'}</option>
                      <option value={`${COACH_CLASSES.find(c => c.code === selectedClass)?.seatPrefix || 'B1-'} Berth 12 (Lower)`}>{language === 'en' ? 'Lower Berth' : 'निचली बर्थ'}</option>
                      <option value={`${COACH_CLASSES.find(c => c.code === selectedClass)?.seatPrefix || 'B1-'} Berth 25 (Middle)`}>{language === 'en' ? 'Middle Berth' : 'मध्यम बर्थ'}</option>
                      <option value={`${COACH_CLASSES.find(c => c.code === selectedClass)?.seatPrefix || 'B1-'} Berth 38 (Upper)`}>{language === 'en' ? 'Upper Berth' : 'ऊपरी बर्थ'}</option>
                      <option value={`${COACH_CLASSES.find(c => c.code === selectedClass)?.seatPrefix || 'B1-'} Berth 44 (Side Lower)`}>{language === 'en' ? 'Side Lower' : 'साइड लोअर'}</option>
                      <option value={`${COACH_CLASSES.find(c => c.code === selectedClass)?.seatPrefix || 'B1-'} Berth 51 (Side Upper)`}>{language === 'en' ? 'Side Upper' : 'साइड अपर'}</option>
                    </select>
                  </div>
                  <div>
                    <span className="text-[10px] text-slate-400 font-bold block">{language === 'en' ? 'Journey Date' : 'यात्रा की तारीख'}</span>
                    <span className="text-xs font-black text-slate-700">{bookingDate}</span>
                  </div>
                </div>
              </div>

              {/* Price Details - 2% admin commission hidden as IRCTC convenience charges */}
              {(() => {
                const classObj = COACH_CLASSES.find(c => c.code === selectedClass);
                const classBase = classObj ? classObj.basePrice : 480;
                const subtotal = selectedTrain.basePrice + classBase;
                const adminProfit = Math.round(subtotal * 0.02);
                const totalPrice = subtotal + adminProfit;

                return (
                  <div className="space-y-4">
                    <div className="border border-slate-100 p-4 rounded-2xl space-y-2 text-xs">
                      <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-2">{language === 'en' ? 'Fare Details' : 'किराया विवरण'}</h4>
                      <div className="flex justify-between font-bold text-slate-500">
                        <span>Base Train Ticket Fare:</span>
                        <span>₹{subtotal}</span>
                      </div>
                      <div className="flex justify-between font-bold text-slate-500">
                        <span>IRCTC Agent Booking & Service Charges:</span>
                        <span>₹{adminProfit}</span>
                      </div>
                      <div className="flex justify-between font-black text-slate-800 pt-2 border-t border-slate-100 text-sm">
                        <span>Total Ticket Amount:</span>
                        <span>₹{totalPrice}</span>
                      </div>
                    </div>

                    {/* Integrated UPI Payment Gateway Box */}
                    {showPaymentGateway && (
                      <div className="bg-gradient-to-br from-indigo-900 to-indigo-950 text-white p-5 rounded-2xl shadow-lg border border-indigo-800 space-y-4">
                        <div className="flex items-center gap-2 border-b border-indigo-800 pb-3">
                          <CreditCard className="h-5 w-5 text-indigo-400" />
                          <h4 className="text-sm font-black">{language === 'en' ? 'Unified Payments Interface (UPI) Gateway' : 'यूपीआई भुगतान गेटवे'}</h4>
                        </div>

                        <div className="space-y-3">
                          <div className="bg-indigo-950/70 p-3 rounded-xl border border-indigo-900/60 text-xs">
                            <div className="flex justify-between py-1">
                              <span className="text-indigo-300 font-bold">Secure Merchant:</span>
                              <span className="font-black">Maudaha Mart Booking Service</span>
                            </div>
                            <div className="flex justify-between py-1">
                              <span className="text-indigo-300 font-bold">UPI ID:</span>
                              <span className="font-black text-indigo-200">dingdang7081@okhdfcbank</span>
                            </div>
                            <div className="flex justify-between py-1 border-t border-indigo-900/40 mt-1.5 pt-1.5 font-black">
                              <span className="text-indigo-300">Amount Payable:</span>
                              <span className="text-indigo-300">₹{totalPrice}</span>
                            </div>
                          </div>

                          <div>
                            <label className="text-[10px] font-black text-indigo-300 uppercase tracking-wider block mb-1">
                              {language === 'en' ? 'Enter Your UPI ID' : 'अपना यूपीआई आईडी दर्ज करें'}
                            </label>
                            <input
                              type="text"
                              value={customerUpiId}
                              onChange={(e) => setCustomerUpiId(e.target.value)}
                              placeholder="e.g. rajesh@upi"
                              className="w-full px-3 py-2 bg-indigo-950/50 border border-indigo-800 rounded-xl text-xs font-bold text-indigo-100 placeholder-indigo-500 focus:outline-none focus:border-indigo-400"
                            />
                          </div>

                          <button
                            onClick={() => {
                              if (!customerUpiId.trim() || !customerUpiId.includes('@')) {
                                alert(language === 'en' ? 'Please enter a valid UPI ID (e.g. name@upi)' : 'कृपया मान्य यूपीआई आईडी दर्ज करें (जैसे name@upi)');
                                return;
                              }
                              setPaymentVerifying(true);
                              setTimeout(() => {
                                setPaymentVerifying(false);
                                handleBookTrainTicket(totalPrice, adminProfit);
                              }, 1800);
                            }}
                            disabled={paymentVerifying}
                            className="w-full py-3 bg-emerald-600 hover:bg-emerald-700 disabled:bg-slate-700 text-white text-xs font-black rounded-xl shadow-md transition active:scale-95 cursor-pointer flex items-center justify-center gap-2"
                          >
                            {paymentVerifying ? (
                              <>
                                <RefreshCw className="h-4 w-4 animate-spin text-white" />
                                <span>Verifying Secure Payment...</span>
                              </>
                            ) : (
                              <>
                                <Shield className="h-4 w-4 text-emerald-300" />
                                <span>Pay ₹{totalPrice} & Reserve Ticket</span>
                              </>
                            )}
                          </button>
                        </div>
                      </div>
                    )}
                  </div>
                );
              })()}
            </div>
          )}

          {/* E-Ticket Reservation Confirmation Pass */}
          {activeSubTab === 'book' && bookedTicket && (
            <div className="bg-white p-6 rounded-3xl border border-indigo-100 shadow-sm space-y-6 animate-in duration-300 relative overflow-hidden">
              <div className="absolute right-0 top-0 translate-x-12 -translate-y-12 bg-indigo-50 h-32 w-32 rounded-full blur-xl"></div>
              
              <div className="flex items-center gap-3 border-b border-indigo-50 pb-4 relative z-10">
                <div className="p-2.5 bg-indigo-50 text-indigo-600 rounded-xl">
                  <CheckCircle className="h-6 w-6 text-indigo-600" />
                </div>
                <div>
                  <span className="text-[10px] font-black text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-lg uppercase tracking-wider">
                    IRCTC Partner Confirmed E-Ticket
                  </span>
                  <h3 className="text-base font-black text-slate-800 mt-1">
                    Booking Success! Happy Journey 🚄
                  </h3>
                </div>
              </div>

              {/* The Boarding Ticket Design */}
              <div className="border border-slate-200 rounded-3xl overflow-hidden shadow-sm relative z-10 bg-slate-50/50">
                {/* Header Ticket strip */}
                <div className="bg-gradient-to-r from-indigo-700 to-indigo-800 text-white px-5 py-3 flex justify-between items-center">
                  <div>
                    <span className="text-[9px] font-bold text-indigo-100 uppercase tracking-widest block leading-none">PNR NUMBER</span>
                    <span className="text-sm font-black tracking-wider leading-none">4328905167</span>
                  </div>
                  <div className="text-right">
                    <span className="text-[9px] font-bold text-indigo-100 uppercase tracking-widest block leading-none">STATUS</span>
                    <span className="text-xs font-black bg-emerald-500 text-white px-2 py-0.5 rounded-lg animate-pulse">CNF (CONFIRMED)</span>
                  </div>
                </div>

                {/* Body Ticket details */}
                <div className="p-5 space-y-4 bg-white">
                  <div className="grid grid-cols-2 gap-4">
                    <div>
                      <span className="text-[10px] text-slate-400 font-bold block uppercase">Train Details</span>
                      <span className="text-xs font-black text-slate-700">{bookedTicket.trainNumber} / {bookedTicket.trainName}</span>
                    </div>
                    <div>
                      <span className="text-[10px] text-slate-400 font-bold block uppercase">Class / Coach</span>
                      <span className="text-xs font-black text-slate-700">{bookedTicket.className}</span>
                    </div>
                  </div>

                  {/* Route strip */}
                  <div className="flex items-center justify-between p-3 bg-slate-50 rounded-2xl border border-slate-100">
                    <div>
                      <span className="text-[9px] font-black text-slate-400 uppercase tracking-wider block">FROM</span>
                      <span className="text-xs font-black text-indigo-900">{bookedTicket.from}</span>
                      <span className="text-[10px] text-slate-500 font-bold block mt-0.5">{bookedTicket.departureTime}</span>
                    </div>
                    <ArrowRight className="h-5 w-5 text-indigo-500" />
                    <div className="text-right">
                      <span className="text-[9px] font-black text-slate-400 uppercase tracking-wider block">TO</span>
                      <span className="text-xs font-black text-indigo-900">{bookedTicket.to}</span>
                      <span className="text-[10px] text-slate-500 font-bold block mt-0.5">{bookedTicket.arrivalTime}</span>
                    </div>
                  </div>

                  <div className="grid grid-cols-2 gap-4 pt-1">
                    <div>
                      <span className="text-[10px] text-slate-400 font-bold block uppercase">Passenger Name</span>
                      <span className="text-xs font-black text-slate-700">{bookedTicket.passengerName}</span>
                    </div>
                    <div>
                      <span className="text-[10px] text-slate-400 font-bold block uppercase">Seat / Berth Assignment</span>
                      <span className="text-xs font-black text-indigo-700">{bookedTicket.seat}</span>
                    </div>
                    <div>
                      <span className="text-[10px] text-slate-400 font-bold block uppercase">Journey Date</span>
                      <span className="text-xs font-black text-slate-700">{bookedTicket.departureDate}</span>
                    </div>
                    <div>
                      <span className="text-[10px] text-slate-400 font-bold block uppercase">Total Fare Paid</span>
                      <span className="text-xs font-black text-emerald-700">₹{bookedTicket.price} (via UPI)</span>
                    </div>
                  </div>

                  {/* QR code and scanner check */}
                  <div className="border-t border-dashed border-slate-200 pt-4 flex flex-col sm:flex-row items-center gap-4 justify-between">
                    <div className="space-y-1">
                      <span className="text-[10px] text-slate-400 font-black uppercase tracking-wider block">Ticket Verification</span>
                      <p className="text-[10px] font-bold text-slate-500 max-w-sm">
                        {language === 'en'
                          ? 'Scan this secured QR code on the hand-held terminal of the Train TTE for direct boarding.'
                          : 'सीधे बोर्डिंग के लिए ट्रेन टीटीई के हैंड-हेल्ड टर्मिनल पर इस सुरक्षित क्यूआर कोड को स्कैन करें।'}
                      </p>
                    </div>
                    <div className="p-2 border border-slate-200 rounded-xl bg-slate-50">
                      <QrCode className="h-16 w-16 text-indigo-900" />
                    </div>
                  </div>
                </div>
              </div>

              {/* Back / Print Options */}
              <div className="flex gap-2 relative z-10">
                <button
                  onClick={() => {
                    setBookedTicket(null);
                    setSelectedTrain(null);
                    setSearchedBookings(false);
                  }}
                  className="flex-1 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-black rounded-2xl shadow-md transition cursor-pointer text-center"
                >
                  {language === 'en' ? 'Book Another Ticket' : 'एक और टिकट बुक करें'}
                </button>
                <button
                  onClick={() => {
                    alert(language === 'en' ? 'Downloading ticket PDF to downloads folder...' : 'टिकट पीडीएफ डाउनलोड फोल्डर में डाउनलोड हो रही है...');
                  }}
                  className="px-5 py-3 border border-slate-200 text-slate-700 hover:bg-slate-50 text-xs font-black rounded-2xl transition cursor-pointer"
                >
                  {language === 'en' ? 'Download Ticket' : 'टिकट डाउनलोड करें'}
                </button>
              </div>
            </div>
          )}

          {/* Active E-Tickets and Past Bookings Ledger */}
          {activeSubTab === 'book' && (
            <div className="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm space-y-4 animate-in duration-300">
              <h3 className="text-xs font-black text-slate-400 uppercase tracking-wider select-none flex items-center gap-1.5">
                <Ticket className="h-3.5 w-3.5 text-slate-400" />
                <span>{language === 'en' ? 'Your Active E-Tickets & Reservation History' : 'आपके सक्रिय ई-टिकट और आरक्षण इतिहास'}</span>
              </h3>

              {(!currentUser?.trainBookings || currentUser.trainBookings.length === 0) ? (
                <div className="p-8 border border-dashed border-slate-100 rounded-2xl text-center text-slate-400 text-xs font-bold">
                  {language === 'en' ? 'No active reservations found on your profile.' : 'आपकी प्रोफ़ाइल पर कोई सक्रिय आरक्षण नहीं मिला।'}
                </div>
              ) : (
                <div className="space-y-3">
                  {currentUser.trainBookings.map((b) => (
                    <div key={b.id} className="p-4 border border-slate-100 rounded-2xl hover:border-indigo-100 transition space-y-2">
                      <div className="flex justify-between items-start">
                        <div>
                          <span className="px-1.5 py-0.5 bg-indigo-50 text-indigo-700 text-[9px] font-black rounded-md">
                            {b.trainNumber}
                          </span>
                          <h4 className="text-xs font-black text-slate-800 mt-1">
                            {b.trainName}
                          </h4>
                          <span className="text-[10px] font-bold text-slate-400 block mt-0.5">
                            {b.from} ➔ {b.to} | {b.departureDate}
                          </span>
                        </div>
                        <span className="text-[10px] font-black text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-lg">
                          Confirmed (CNF)
                        </span>
                      </div>
                      
                      <div className="flex flex-wrap justify-between items-center text-[10px] font-bold text-slate-500 border-t border-slate-50 pt-1.5">
                        <span>Passenger: <span className="font-black text-slate-700">{b.passengerName}</span></span>
                        <span>Seat: <span className="font-black text-indigo-700">{b.seat}</span></span>
                        <span>Class: <span className="font-black text-slate-700">{b.className}</span></span>
                      </div>

                      <div className="pt-1.5 border-t border-slate-50 flex justify-between items-center">
                        <span className="text-[10px] text-indigo-700 font-black bg-indigo-50 border border-indigo-100 px-1.5 py-0.5 rounded">
                          {language === 'en' ? `Total Fare Paid: ₹${b.price} (via UPI)` : `कुल भुगतान किराया: ₹${b.price} (यूपीआई द्वारा)`}
                        </span>
                        <button
                          onClick={() => {
                            setBookedTicket(b);
                          }}
                          className="text-[10px] font-black text-indigo-600 hover:underline cursor-pointer"
                        >
                          {language === 'en' ? 'View E-Ticket' : 'ई-टिकट देखें'}
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}

          {/* Placeholder when no search executed yet */}
          {activeSubTab === 'status' && !searchResult && (
            <div className="bg-white border border-slate-100 rounded-3xl p-8 text-center space-y-6 shadow-sm animate-in fade-in duration-300">
              <div className="mx-auto w-16 h-16 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center text-2xl shadow-sm">
                🛰️
              </div>
              <div className="max-w-md mx-auto space-y-2">
                <h3 className="text-base font-black text-slate-800">
                  {language === 'en' ? 'Live GPS Train Tracker' : 'लाइव जीपीएस ट्रेन ट्रैकर'}
                </h3>
                <p className="text-xs text-slate-500 font-medium">
                  {language === 'en' 
                    ? 'Spot train positions, delayed times, and expected arrival platforms on our satellite visual track.' 
                    : 'हमारे उपग्रह विज़ुअल ट्रैक पर ट्रेन की स्थिति, देरी के समय और अपेक्षित आगमन प्लेटफॉर्म का पता लगाएं।'}
                </p>
              </div>

              {/* Step instructions */}
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2 text-left max-w-lg mx-auto">
                <div className="p-3 bg-slate-50/70 border border-slate-100 rounded-2xl flex gap-3">
                  <span className="text-xs font-black text-indigo-600 bg-indigo-50 w-6 h-6 rounded-lg flex items-center justify-center shrink-0">1</span>
                  <div>
                    <span className="text-xs font-black text-slate-700 block">{language === 'en' ? 'Select Train' : 'ट्रेन चुनें'}</span>
                    <span className="text-[11px] text-slate-500 font-bold block">{language === 'en' ? 'Enter train name/number on the left pane' : 'बाईं ओर ट्रेन का नाम या नंबर डालें'}</span>
                  </div>
                </div>
                <div className="p-3 bg-slate-50/70 border border-slate-100 rounded-2xl flex gap-3">
                  <span className="text-xs font-black text-indigo-600 bg-indigo-50 w-6 h-6 rounded-lg flex items-center justify-center shrink-0">2</span>
                  <div>
                    <span className="text-xs font-black text-slate-700 block">{language === 'en' ? 'Live Track' : 'लाइव ट्रैक'}</span>
                    <span className="text-[11px] text-slate-500 font-bold block">{language === 'en' ? 'Get automatic route updates and station halts' : 'स्वचालित रूट अपडेट और स्टेशन ठहराव प्राप्त करें'}</span>
                  </div>
                </div>
              </div>

              {/* Fast shortcuts list */}
              <div className="pt-4 border-t border-slate-100 space-y-3">
                <span className="text-[10px] font-black text-slate-400 uppercase tracking-wider block">
                  {language === 'en' ? '⚡ Or Tap a Popular Train to Spot Instantly' : '⚡ या तुरंत स्पॉट करने के लिए लोकप्रिय ट्रेन पर टैप करें'}
                </span>
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-2 max-w-md mx-auto">
                  {POPULAR_TRAINS.map((t) => (
                    <button
                      key={t.number}
                      onClick={() => {
                        setTrainNo(t.number);
                        handleSearchStatus(t.number);
                      }}
                      className="flex items-center justify-between p-2.5 bg-indigo-50/40 hover:bg-indigo-50 border border-indigo-100/50 hover:border-indigo-200 rounded-xl transition text-left cursor-pointer text-xs"
                    >
                      <div className="truncate">
                        <span className="font-black text-slate-800 block truncate">{language === 'en' ? t.name : t.nameHi}</span>
                        <span className="text-[10px] text-slate-500 font-bold">No: {t.number}</span>
                      </div>
                      <ArrowRight className="h-3.5 w-3.5 text-indigo-500 shrink-0" />
                    </button>
                  ))}
                </div>
              </div>
            </div>
          )}

          {activeSubTab === 'pnr' && !pnrResult && (
            <div className="bg-white border border-slate-100 rounded-3xl p-8 text-center space-y-6 shadow-sm animate-in fade-in duration-300">
              <div className="mx-auto w-16 h-16 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center text-2xl shadow-sm">
                🔍
              </div>
              <div className="max-w-md mx-auto space-y-2">
                <h3 className="text-base font-black text-slate-800">
                  {language === 'en' ? 'PNR Seat & Allotment Search' : 'पीएनआर सीट और आवंटन खोज'}
                </h3>
                <p className="text-xs text-slate-500 font-medium">
                  {language === 'en' 
                    ? 'Enter your 10-digit reservation number on the left panel to check live coach number, waitlist clearance, and berth position.' 
                    : 'सक्रिय कोच नंबर, प्रतीक्षा सूची और सीट की स्थिति की जांच करने के लिए बाईं ओर 10-अंकीय पीएनआर दर्ज करें।'}
                </p>
              </div>

              {/* Sample Ticket Visual */}
              <div className="bg-slate-50/50 border border-dashed border-slate-200 rounded-2xl p-4 max-w-sm mx-auto text-left space-y-3 opacity-80">
                <div className="flex justify-between items-center text-[10px] font-black text-slate-400 uppercase tracking-wider pb-1.5 border-b border-slate-200/50">
                  <span>Sample PNR Enquiry</span>
                  <span className="text-indigo-600">CNF / Confirmed</span>
                </div>
                <div className="grid grid-cols-2 gap-2 text-xs font-bold text-slate-600">
                  <div>
                    <span className="text-[9px] text-slate-400 block uppercase">TRAIN No</span>
                    <span>11110 - Bundelkhand Exp</span>
                  </div>
                  <div>
                    <span className="text-[9px] text-slate-400 block uppercase">COACH / SEAT</span>
                    <span>Coach S3, Berth 24 (Middle)</span>
                  </div>
                </div>
              </div>
            </div>
          )}

          {activeSubTab === 'book' && !searchedBookings && !selectedTrain && !bookedTicket && (
            <div className="bg-white border border-slate-100 rounded-3xl p-8 text-center space-y-6 shadow-sm animate-in fade-in duration-300">
              <div className="mx-auto w-16 h-16 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center text-2xl shadow-sm">
                🎫
              </div>
              <div className="max-w-md mx-auto space-y-2">
                <h3 className="text-base font-black text-slate-800">
                  {language === 'en' ? 'Book Train Tickets Instantly' : 'तुरंत ट्रेन टिकट बुक करें'}
                </h3>
                <p className="text-xs text-slate-500 font-medium">
                  {language === 'en' 
                    ? 'Search train schedules from Ragaul (RGU) to major hubs. Complete reservations instantly with secure UPI billing.' 
                    : 'रागौल (आरजीयू) से प्रमुख गंतव्यों के लिए ट्रेनें खोजें। सुरक्षित यूपीआई बिलिंग के साथ तुरंत अपना आरक्षण पूरा करें।'}
                </p>
              </div>

              {/* Booking promo benefits */}
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-lg mx-auto pt-2">
                <div className="p-3 bg-emerald-50/40 border border-emerald-100/30 rounded-2xl">
                  <span className="text-lg block mb-1">⚡</span>
                  <span className="text-[11px] font-black text-slate-800 block">{language === 'en' ? 'Instant Issuance' : 'त्वरित टिकट'}</span>
                  <span className="text-[9px] text-slate-500 font-bold">{language === 'en' ? 'No verification delay' : 'कोई देरी नहीं'}</span>
                </div>
                <div className="p-3 bg-indigo-50/40 border border-indigo-100/30 rounded-2xl">
                  <span className="text-lg block mb-1">🛡️</span>
                  <span className="text-[11px] font-black text-slate-800 block">{language === 'en' ? 'Secure Payment' : 'सुरक्षित भुगतान'}</span>
                  <span className="text-[9px] text-slate-500 font-bold">{language === 'en' ? 'Via secure UPI gateways' : 'सत्यापित गेटवे'}</span>
                </div>
                <div className="p-3 bg-amber-50/40 border border-amber-100/30 rounded-2xl">
                  <span className="text-lg block mb-1">💬</span>
                  <span className="text-[11px] font-black text-slate-800 block">{language === 'en' ? 'E-Ticket QR' : 'क्यूआर ई-टिकट'}</span>
                  <span className="text-[9px] text-slate-500 font-bold">{language === 'en' ? 'Show directly to TTE' : 'टीटीई सत्यापन'}</span>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
